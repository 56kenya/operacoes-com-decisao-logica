using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace exercicio_6
{
    internal class Program
    {
        static void Main(string[] args)
        {
            int vbase;
            int valtura;
            int terreno;

            Console.WriteLine("Insira o valor da base: ");
            vbase = int.Parse(Console.ReadLine());

            Console.WriteLine("Insira o valor da altura: ");
            valtura = int.Parse(Console.ReadLine());

            terreno = vbase * valtura;

            if (terreno < 100)
            {
                Console.WriteLine("Terreno pequeno");
            }
            else if (terreno > 100)
            { 
                Console.WriteLine("Terreno grande");
            }

        }
    }
}
